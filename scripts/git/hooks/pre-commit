#!/bin/bash

# Git pre-commit hook
# 用途：防止在 main 分支上直接提交，并检查提交信息格式

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

# 检查当前分支
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 检查是否在 main 分支上
if [ "$CURRENT_BRANCH" = "main" ]; then
    print_error "不允许在 main 分支上直接提交！"
    echo ""
    print_warning "请遵循 Git 工作流："
    echo "  1. 使用 './scripts/git/start-branch.sh' 创建新分支"
    echo "  2. 在新分支上进行开发"
    echo "  3. 通过 Pull Request 合并到 main"
    echo ""
    echo "如需紧急修复 main 分支，请使用 --no-verify 参数跳过此检查："
    echo "  git commit --no-verify -m \"...\""
    echo ""
    exit 1
fi

# 获取提交信息（如果是 git commit，从 .git/COMMIT_EDITMSG 读取）
if [ -f .git/COMMIT_EDITMSG ]; then
    COMMIT_MSG=$(cat .git/COMMIT_EDITMSG)
else
    # 对于其他情况，从 stdin 读取
    COMMIT_MSG=$(cat)
fi

# 检查提交信息格式（Conventional Commits）
# 格式：type(scope): subject
# 或简单的：type: subject

COMMIT_PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\(.+\))?: .{1,}"

if ! echo "$COMMIT_MSG" | grep -qE "$COMMIT_PATTERN"; then
    print_error "提交信息格式不符合 Conventional Commits 规范"
    echo ""
    echo "正确格式示例："
    echo "  feat: add user authentication"
    echo "  fix(api): resolve timeout issue"
    echo "  docs: update README"
    echo "  refactor: simplify state management"
    echo ""
    echo "允许的 type: feat, fix, docs, style, refactor, perf, test, chore, ci, revert"
    echo ""
    echo "如需跳过此检查，请使用 --no-verify 参数："
    echo "  git commit --no-verify -m \"...\""
    echo ""
    exit 1
fi

# 提交信息长度检查（第一行不超过 72 个字符）
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)
if [ ${#FIRST_LINE} -gt 72 ]; then
    print_error "提交信息第一行超过 72 个字符限制（当前：${#FIRST_LINE} 个字符）"
    echo ""
    echo "第一行内容："
    echo "  $FIRST_LINE"
    echo ""
    exit 1
fi

# 检查是否有空行分隔主题和正文
BODY_START=$(echo "$COMMIT_MSG" | grep -n "^$" | head -n 1 | cut -d: -f1)
if [ -n "$BODY_START" ]; then
    # 如果有正文，检查第二行是否为空
    SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n "${BODY_START}p")
    if [ -n "$SECOND_LINE" ]; then
        print_warning "建议在主题和正文之间保留空行"
    fi
fi

print_success "提交信息格式检查通过"
